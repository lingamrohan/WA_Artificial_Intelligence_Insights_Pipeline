# --- DATABASE ---
# Prisma uses this to connect to your SQLite file
DATABASE_URL="file:./dev.db"

# --- SERVER ---
PORT=3000

# --- OPENAI ---
# Replace with your actual key from platform.openai.com
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx"

# --- META / WHATSAPP WEBHOOK ---
# This MUST match the value in your code: "my_secret_token_123"
WEBHOOK_VERIFY_TOKEN="my_secret_token_123"

# --- OPTIONAL CONFIG ---
# Since your code references "gpt-3.5-turbo-0125", 
# you can use this to swap models without changing code later
AI_MODEL="gpt-3.5-turbo-0125"
